{
  "name": "runbook",
  "version": "0.1.0",
  "private": true,
  "description": "Executable user manual pipeline",
  "type": "module",
  "bin": {
    "runbook": "./dist/cli.js"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json",
    "check": "bunx tsc -p tsconfig.json --noEmit",
    "dev": "bun run src/cli.ts dev",
    "runbook": "bun run src/cli.ts",
    "runbook:build": "bun run src/cli.ts build",
    "runbook:capture": "bun run src/cli.ts capture",
    "runbook:check": "bun run src/cli.ts check"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.6",
  "devDependencies": {
    "@types/node": "^24.6.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3"
  }
}
