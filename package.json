{
  "name": "runbook",
  "version": "0.1.0",
  "private": true,
  "description": "Executable user manual pipeline",
  "type": "module",
  "bin": {
    "runbook": "./dist/cli.js"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "bunx tsc -p tsconfig.json --noEmit",
    "dev": "bun run src/cli.ts dev",
    "test": "bun test",
    "runbook:link": "bun run build && npm link",
    "runbook": "bun run src/cli.ts",
    "runbook:build": "bun run src/cli.ts build",
    "runbook:capture": "bun run src/cli.ts capture",
    "runbook:check": "bun run src/cli.ts check",
    "runbook:doctor": "bun run src/cli.ts doctor",
    "runbook:init": "bun run src/cli.ts init",
    "runbook:sample:build": "bun run src/cli.ts build --config manual/sample/manual.config.mjs",
    "runbook:sample:capture": "bun run src/cli.ts capture --config manual/sample/manual.config.mjs",
    "runbook:sample:check": "bun run src/cli.ts check --config manual/sample/manual.config.mjs",
    "runbook:sample:doctor": "bun run src/cli.ts doctor --config manual/sample/manual.config.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.6",
  "devDependencies": {
    "@types/node": "^24.6.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
